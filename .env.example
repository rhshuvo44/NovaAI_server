# ==============================================================================
# AI Workspace Backend - Environment Configuration
# Copy this file to .env and fill in real values before running the app.
# ==============================================================================

# --- App ---
NODE_ENV=development
PORT=5000
API_VERSION=v1
APP_NAME=AI Workspace
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai-workspace?retryWrites=true&w=majority
MONGODB_URI_TEST=mongodb://localhost:27017/ai-workspace-test

# --- Internal JWT (refresh token signing) ---
JWT_ACCESS_SECRET=replace_with_a_random_32+_char_secret
JWT_REFRESH_SECRET=replace_with_a_different_random_32+_char_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- AI Providers ---
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# --- Cloudinary (file uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Email ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=AI Workspace <noreply@yourdomain.com>

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL=info

# --- Seed User Passwords (optional — defaults in env.ts) ---
ADMIN_PASSWORD=Admin@123
MANAGER_PASSWORD=Manager@123
USER_PASSWORD=User@123

# --- Security ---
BCRYPT_SALT_ROUNDS=12
COOKIE_SECRET=replace_with_a_random_32+_char_secret
