# ==============================================================================
# AI Workspace Backend - Environment Configuration
# Copy this file to .env and fill in real values before running the app.
# Every variable below has a safe placeholder default in src/config/env.ts,
# so the app will boot without a .env file, but external integrations
# (Clerk, OpenAI/Gemini, Cloudinary, Resend/SMTP) will not function until
# real credentials are provided.
# ==============================================================================

# --- App ---
NODE_ENV=development
PORT=5000
API_VERSION=v1
APP_NAME=AI Workspace
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# --- MongoDB Atlas ---
# Get your connection string from MongoDB Atlas > Database > Connect
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai-workspace?retryWrites=true&w=majority
MONGODB_URI_TEST=mongodb://localhost:27017/ai-workspace-test

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_TLS=false
REDIS_DB=0

# --- Clerk Authentication ---
# https://dashboard.clerk.com -> API Keys
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_JWT_KEY=
# https://dashboard.clerk.com -> Webhooks -> Signing Secret
CLERK_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# --- Internal JWT (refresh token signing) ---
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_a_random_32+_char_secret
JWT_REFRESH_SECRET=replace_with_a_different_random_32+_char_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- AI Providers ---
# AI_PROVIDER selects which provider getAIProvider() returns by default: openai | gemini
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# --- Cloudinary (file uploads) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Email ---
# EMAIL_PROVIDER selects the primary sender: resend | nodemailer (SMTP fallback always available)
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_resend_api_key
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=AI Workspace <noreply@yourdomain.com>

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL=info

# --- Security ---
BCRYPT_SALT_ROUNDS=12
COOKIE_SECRET=replace_with_a_random_32+_char_secret
